{
  "id": "IN-01",
  "category": "Integration / API",
  "title": "API Chain Agent",
  "description": "Generates intelligent API orchestrators with sequential call execution, data passing between calls, response transformation, retry with exponential backoff, circuit breaker pattern, and parallel execution.",
  "system_prompt": "You are an expert API integration architect specializing in intelligent API orchestration, workflow automation, and stateful multi-step API chains. You create production-grade autonomous API agents with request chaining, response transformation, error handling, retry logic, and persistent state management. Your code follows best practices for HTTP clients, implements TypeScript types, includes rate limiting, circuit breakers, and comprehensive error recovery.\n\nInternal Chain-of-Thought Process:\nStep 1: Analyze the requirements, constraints, and edge cases provided.\nStep 2: Execute the chain sequentially \u2014 validate inputs, design structure, implement logic with error handling.\nStep 3: Output ONLY valid, complete production-ready code with no placeholders or TODOs.\n\nYou MUST follow the exact schema structure provided. All outputs must be parseable JSON matching the specified output_format.",
  "user_prompt_template": "Generate production-ready code based on the following specification:\n\nTask: {{task}}\nConstraints: {{constraints}}\nChain Steps: {{chain_steps}}\nMemory State: {{memory_state}}\nOutput Format: {{output_format}}\n\nRespond with ONLY a JSON object matching the output_format structure exactly.",
  "tool_schema": {
    "name": "generate_api_chain_agent",
    "description": "Generates intelligent API orchestrators with sequential call execution, data passing between calls, response transformation, retry with exponential backoff, circuit breaker pattern, and parallel execution.",
    "input_schema": {
      "type": "object",
      "properties": {
        "task": {
          "type": "string",
          "enum": [
            "api_chain"
          ]
        },
        "constraints": {
          "type": "object",
          "properties": {
            "calls": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "endpoint": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "GET",
                      "POST",
                      "PUT",
                      "PATCH",
                      "DELETE"
                    ]
                  }
                },
                "required": [
                  "name",
                  "endpoint",
                  "method"
                ]
              }
            },
            "auth_type": {
              "type": "string",
              "enum": [
                "bearer",
                "api-key",
                "basic",
                "none"
              ],
              "default": "bearer"
            },
            "parallel_enabled": {
              "type": "boolean",
              "default": false
            },
            "circuit_breaker": {
              "type": "boolean",
              "default": true
            },
            "max_tokens": {
              "type": "integer",
              "default": 3000
            }
          },
          "required": [
            "calls"
          ]
        },
        "chain_steps": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "call_1",
              "transform",
              "call_2",
              "aggregate",
              "error_recovery",
              "consolidate"
            ]
          },
          "minItems": 2
        },
        "memory_state": {
          "type": "object",
          "properties": {
            "cache": {
              "type": "string",
              "default": "Map<string, any>"
            },
            "circuit_state": {
              "type": "string",
              "default": "'closed'|'open'|'half-open'"
            },
            "retry_count": {
              "type": "string",
              "default": "number"
            }
          }
        },
        "output_format": {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "chain_executed": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "apis_called": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "features_implemented": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "memory_state": {
                  "type": "object"
                }
              },
              "required": [
                "code",
                "chain_executed",
                "apis_called"
              ]
            }
          },
          "required": [
            "data"
          ]
        }
      },
      "required": [
        "task",
        "constraints",
        "chain_steps",
        "memory_state",
        "output_format"
      ]
    }
  },
  "tool_choice": {
    "type": "tool",
    "name": "generate_api_chain_agent"
  },
  "example_usage": {
    "input": {
      "task": "api_chain",
      "constraints": {
        "calls": [
          {
            "name": "getUser",
            "endpoint": "https://api.example.com/users/{id}",
            "method": "GET"
          },
          {
            "name": "getUserPosts",
            "endpoint": "https://api.example.com/posts?userId={userId}",
            "method": "GET"
          }
        ],
        "auth_type": "bearer",
        "circuit_breaker": true
      },
      "chain_steps": [
        "call_1",
        "transform",
        "call_2",
        "aggregate"
      ],
      "memory_state": {
        "cache": "Map",
        "circuit_state": "closed"
      },
      "output_format": {
        "data": {
          "code": "string",
          "chain_executed": "array",
          "apis_called": "array",
          "features_implemented": "array",
          "memory_state": "object"
        }
      }
    },
    "expected_output": {
      "data": {
        "code": "class ApiChainAgent {\n  async execute() {\n    const user = await this.call('getUser', { id: this.config.userId });\n    const posts = await this.call('getUserPosts', { userId: user.id });\n    return this.aggregate([user, posts]);\n  }\n}",
        "chain_executed": [
          "call_1",
          "transform",
          "call_2",
          "aggregate"
        ],
        "apis_called": [
          "https://api.example.com/users/{id}",
          "https://api.example.com/posts?userId={userId}"
        ],
        "features_implemented": [
          "sequential-chaining",
          "data-passing",
          "circuit-breaker",
          "exponential-backoff",
          "response-transformation"
        ],
        "memory_state": {
          "cache": {},
          "circuit_state": "closed"
        }
      }
    }
  },
  "reliability_note": "API chain orchestrator with sequential execution, response transformation, circuit breaker, and parallel call support. Achieves 95%+ parseability through strict schema enforcement, enum constraints, and sequential chain-of-thought execution. Compatible with both Anthropic tool_use and OpenAI function_calling APIs.",
  "compatible_models": [
    "claude-opus-4-7",
    "claude-sonnet-4-6",
    "claude-opus-4-6",
    "claude-haiku-4-5-20251001",
    "gpt-4o",
    "gpt-4-turbo"
  ],
  "api_compatibility": [
    "Anthropic tool_use API",
    "OpenAI function_calling API"
  ],
  "version": "2.0",
  "last_updated": "2025-2026"
}